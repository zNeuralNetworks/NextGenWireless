{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "App.tsx",
    "index.tsx",
    "vite.config.ts",
    "store.ts",
    "constants.ts",
    "constants/**/*.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lucide-icons.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-ssr",
    ".code-review-graph",
    ".claude",
    ".cursor",
    ".kiro",
    ".qoder",
    "migrated_prompt_history"
  ]
}
