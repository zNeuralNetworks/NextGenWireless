# Runtime OAuth configuration
# Local development can use:
#   npm run build
#   npm start
#
# Register this redirect URI in the Google OAuth client:
#   http://localhost:8080/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# Comma-separated allowlist. These are the production admins by default.
ADMIN_EMAILS=tinurajan1@gmail.com,theorajan1@gmail.com

# Optional. The server uses a relative callback path by default.
OAUTH_CALLBACK_URL=/auth/google/callback
